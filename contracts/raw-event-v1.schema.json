{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://polymarket-money.local/contracts/raw-event-v1.schema.json",
  "title": "RawEventEnvelope v1",
  "description": "Persisted, credential-free envelope for exact public raw messages. Vendor payload fields remain inside raw_payload and are never silently discarded.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "event_id",
    "source",
    "stream",
    "event_type",
    "connection_id",
    "subscription_id",
    "market_id",
    "condition_id",
    "asset_id",
    "source_time",
    "server_time",
    "receive_time",
    "process_time",
    "persist_time",
    "source_sequence",
    "source_hash",
    "raw_payload",
    "raw_sha256",
    "parser_status",
    "parser_error"
  ],
  "properties": {
    "schema_version": {"const": "raw-event-v1"},
    "event_id": {"type": "string", "minLength": 1},
    "source": {"type": "string", "minLength": 1},
    "stream": {"type": "string", "minLength": 1},
    "event_type": {"type": "string", "minLength": 1},
    "connection_id": {"type": "string", "minLength": 1},
    "subscription_id": {"type": "string", "minLength": 1},
    "market_id": {"type": ["string", "null"], "minLength": 1},
    "condition_id": {"type": ["string", "null"], "minLength": 1},
    "asset_id": {"type": ["string", "null"], "minLength": 1},
    "source_time": {"$ref": "#/$defs/nullableUtcTime"},
    "server_time": {"$ref": "#/$defs/nullableUtcTime"},
    "receive_time": {"$ref": "#/$defs/utcTime"},
    "process_time": {"$ref": "#/$defs/utcTime"},
    "persist_time": {"$ref": "#/$defs/utcTime"},
    "source_sequence": {
      "description": "A source-defined sequence represented as a string to avoid IEEE-754 loss; null when the source provides none.",
      "type": ["string", "null"],
      "minLength": 1
    },
    "source_hash": {"type": ["string", "null"], "minLength": 1},
    "raw_payload": {
      "description": "Exact UTF-8 message text captured before parsing or normalization.",
      "type": "string"
    },
    "raw_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "parser_status": {
      "enum": ["parsed", "unparsed", "error", "quarantined"]
    },
    "parser_error": {"type": ["string", "null"], "minLength": 1}
  },
  "allOf": [
    {
      "if": {"properties": {"parser_status": {"const": "error"}}},
      "then": {"properties": {"parser_error": {"type": "string", "minLength": 1}}},
      "else": {"properties": {"parser_error": {"type": "null"}}}
    }
  ],
  "$defs": {
    "utcTime": {
      "type": "string",
      "description": "Canonical UTC time with exactly millisecond precision.",
      "format": "date-time",
      "pattern": "^[0-9]{4}-(0[1-9]|1[0-2])-([0-2][0-9]|3[01])T([01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]\\.[0-9]{3}Z$"
    },
    "nullableUtcTime": {
      "oneOf": [
        {"$ref": "#/$defs/utcTime"},
        {"type": "null"}
      ]
    }
  }
}
