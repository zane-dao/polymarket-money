{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://polymarket-money.local/contracts/normalized-record-v1.schema.json",
  "title": "Point-in-time normalized record v1",
  "description": "Immutable normalized facts and quarantines derived only from manifest-verified public raw data.",
  "oneOf": [
    {"$ref": "#/$defs/fact"},
    {"$ref": "#/$defs/quarantine"}
  ],
  "$defs": {
    "utcTime": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-(0[1-9]|1[0-2])-([0-2][0-9]|3[01])T([01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]\\.[0-9]{3}Z$"
    },
    "nullableUtcTime": {
      "oneOf": [
        {"$ref": "#/$defs/utcTime"},
        {"type": "null"}
      ]
    },
    "nullableId": {
      "type": ["string", "null"],
      "minLength": 1
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "lineage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_manifest_id",
        "source_manifest_sha256",
        "segment_sha256",
        "segment_ordinal",
        "line_ordinal",
        "message_ordinal",
        "event_id",
        "raw_sha256",
        "raw_persist_time",
        "visible_at"
      ],
      "properties": {
        "source_manifest_id": {"type": "string", "minLength": 1},
        "source_manifest_sha256": {"$ref": "#/$defs/sha256"},
        "segment_sha256": {"$ref": "#/$defs/sha256"},
        "segment_ordinal": {"type": "integer", "minimum": 0},
        "line_ordinal": {"type": "integer", "minimum": 0},
        "message_ordinal": {"type": "integer", "minimum": 0},
        "event_id": {"type": "string", "minLength": 1},
        "raw_sha256": {"$ref": "#/$defs/sha256"},
        "raw_persist_time": {"$ref": "#/$defs/utcTime"},
        "visible_at": {"$ref": "#/$defs/utcTime"}
      }
    },
    "fact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "record_id",
        "record_type",
        "business_key",
        "market_id",
        "condition_id",
        "asset_id",
        "source",
        "source_time",
        "server_time",
        "receive_time",
        "process_time",
        "persist_time",
        "visible_at",
        "continuity",
        "connection_id",
        "parser_state",
        "observed_at",
        "valid_from",
        "payload",
        "duplicate_count",
        "raw_lineage",
        "dependency_lineage"
      ],
      "properties": {
        "schema_version": {"const": "normalized-record-v1"},
        "record_id": {"$ref": "#/$defs/sha256"},
        "record_type": {
          "enum": [
            "market_metadata",
            "outcome_token_mapping",
            "clob_book_state",
            "chainlink_btc_usd",
            "binance_btc_usdt",
            "connection_state",
            "quality_interval"
          ]
        },
        "business_key": {"type": "string", "minLength": 1},
        "market_id": {"$ref": "#/$defs/nullableId"},
        "condition_id": {"$ref": "#/$defs/nullableId"},
        "asset_id": {"$ref": "#/$defs/nullableId"},
        "source": {"type": "string", "minLength": 1},
        "source_time": {"$ref": "#/$defs/nullableUtcTime"},
        "server_time": {"$ref": "#/$defs/nullableUtcTime"},
        "receive_time": {"$ref": "#/$defs/utcTime"},
        "process_time": {"$ref": "#/$defs/utcTime"},
        "persist_time": {"$ref": "#/$defs/utcTime"},
        "visible_at": {"$ref": "#/$defs/utcTime"},
        "continuity": {"const": "UNVERIFIED"},
        "connection_id": {"type": "string", "minLength": 1},
        "parser_state": {"enum": ["parsed", "unparsed", "error", "quarantined"]},
        "observed_at": {"$ref": "#/$defs/nullableUtcTime"},
        "valid_from": {"$ref": "#/$defs/nullableUtcTime"},
        "payload": {"type": "object"},
        "duplicate_count": {"type": "integer", "minimum": 1},
        "raw_lineage": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/lineage"}
        },
        "dependency_lineage": {
          "description": "Raw facts used to classify or enrich this record, such as the Gamma identity that binds a token or price to a five-minute market.",
          "type": "array",
          "items": {"$ref": "#/$defs/lineage"}
        }
      }
    },
    "quarantine": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "quarantine_id",
        "reason_code",
        "business_key",
        "market_id",
        "asset_id",
        "visible_at",
        "affected_record_ids",
        "raw_lineage",
        "dependency_lineage"
      ],
      "properties": {
        "schema_version": {"const": "normalized-record-v1"},
        "quarantine_id": {"$ref": "#/$defs/sha256"},
        "reason_code": {"type": "string", "minLength": 1},
        "business_key": {"type": "string", "minLength": 1},
        "market_id": {"$ref": "#/$defs/nullableId"},
        "asset_id": {"$ref": "#/$defs/nullableId"},
        "visible_at": {"$ref": "#/$defs/utcTime"},
        "affected_record_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/sha256"}
        },
        "raw_lineage": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/lineage"}
        },
        "dependency_lineage": {
          "description": "Raw facts needed to assign this quarantine to a market or token.",
          "type": "array",
          "items": {"$ref": "#/$defs/lineage"}
        }
      }
    }
  }
}
