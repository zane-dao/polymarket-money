{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Polymarket BTC 5m Workbench",
  "version": "0.1.0",
  "identifier": "local.polymarket-money.workbench",
  "build": {
    "beforeDevCommand": "npm run build && npm run frontend:dev",
    "beforeBuildCommand": "npm run build && npm run frontend:build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "windows": [{ "title": "Polymarket BTC 5m Workbench", "width": 1440, "height": 1000, "minWidth": 900, "minHeight": 640 }],
    "security": { "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:" }
  },
  "bundle": { "active": false, "icon": [] }
}
