# Safety default. This scaffold contains no live-trading implementation.
LIVE_TRADING_ENABLED=false
DRY_RUN=true
CREDENTIAL_MODE=none
EXPLICIT_LIVE_AUTHORIZATION=false

# Do not place real credentials in this file or commit them to Git.
APP_ENV=development
LOG_LEVEL=info

# Public raw capture only. Keep this absolute path outside the Git repository.
POLY_DATA_ROOT=/root/polymarket-money-data
