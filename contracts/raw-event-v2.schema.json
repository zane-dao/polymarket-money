{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://polymarket-money.local/contracts/raw-event-v2.schema.json",
  "title": "RawEventEnvelope v2",
  "description": "Persisted public raw event with a process-local monotonic ReceiveStamp. Wall time is retained for audit but not subsecond ordering.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "event_id", "source", "stream", "event_type",
    "transport_connection_id", "subscription_id", "market_id", "condition_id", "asset_id",
    "provider_source_time", "provider_server_time", "local_wall_receive_time",
    "local_monotonic_receive_ns", "local_receive_ordinal", "clock_domain", "process_time",
    "persist_time", "source_sequence", "source_hash", "raw_payload", "raw_sha256",
    "parser_status", "parser_error"
  ],
  "properties": {
    "schema_version": {"const": "raw-event-v2"},
    "event_id": {"type": "string", "minLength": 1},
    "source": {"type": "string", "minLength": 1},
    "stream": {"type": "string", "minLength": 1},
    "event_type": {"type": "string", "minLength": 1},
    "transport_connection_id": {"type": "string", "minLength": 1},
    "subscription_id": {"type": "string", "minLength": 1},
    "market_id": {"type": ["string", "null"], "minLength": 1},
    "condition_id": {"type": ["string", "null"], "minLength": 1},
    "asset_id": {"type": ["string", "null"], "minLength": 1},
    "provider_source_time": {"$ref": "#/$defs/nullableUtcTime"},
    "provider_server_time": {"$ref": "#/$defs/nullableUtcTime"},
    "local_wall_receive_time": {"$ref": "#/$defs/utcTime"},
    "local_monotonic_receive_ns": {"type": "string", "pattern": "^(?:0|[1-9][0-9]*)$"},
    "local_receive_ordinal": {"type": "string", "pattern": "^[1-9][0-9]*$"},
    "clock_domain": {"type": "string", "minLength": 1},
    "process_time": {"$ref": "#/$defs/utcTime"},
    "persist_time": {"$ref": "#/$defs/utcTime"},
    "source_sequence": {"type": ["string", "null"], "minLength": 1},
    "source_hash": {"type": ["string", "null"], "minLength": 1},
    "raw_payload": {"type": "string"},
    "raw_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "parser_status": {"enum": ["parsed", "unparsed", "error", "quarantined"]},
    "parser_error": {"type": ["string", "null"], "minLength": 1}
  },
  "allOf": [{
    "if": {"properties": {"parser_status": {"const": "error"}}},
    "then": {"properties": {"parser_error": {"type": "string", "minLength": 1}}},
    "else": {"properties": {"parser_error": {"type": "null"}}}
  }],
  "$defs": {
    "utcTime": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-(0[1-9]|1[0-2])-([0-2][0-9]|3[01])T([01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]\\.[0-9]{3}Z$"
    },
    "nullableUtcTime": {"oneOf": [{"$ref": "#/$defs/utcTime"}, {"type": "null"}]}
  }
}
