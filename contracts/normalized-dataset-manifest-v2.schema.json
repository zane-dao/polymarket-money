{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://polymarket-money.local/contracts/normalized-dataset-manifest-v2.schema.json",
  "title": "Normalized dataset manifest V2",
  "type": "object",
  "required": ["schema_version", "normalized_schema_version", "dataset_id", "continuity", "min_source_time", "max_source_time", "quarantine_count", "raw_input_hashes", "outputs", "metadata", "dataset_hash"],
  "properties": {
    "schema_version": {"const": "normalized-dataset-manifest-v2"},
    "normalized_schema_version": {"const": "unified-market-event-v1"},
    "dataset_id": {"type": "string", "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._-]{0,95}$"},
    "continuity": {"const": "UNVERIFIED"},
    "min_source_time": {"type": "string", "format": "date-time"},
    "max_source_time": {"type": "string", "format": "date-time"},
    "quarantine_count": {"type": "integer", "minimum": 0},
    "raw_input_hashes": {"type": "array", "items": {"type": "string", "pattern": "^[0-9a-f]{64}$"}},
    "outputs": {"type": "object", "minProperties": 1},
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["published_at_utc", "name", "description", "source", "tags"],
      "properties": {
        "published_at_utc": {"type": "string", "format": "date-time"},
        "name": {"type": "string", "minLength": 1},
        "description": {"type": "string", "minLength": 1},
        "source": {"type": "string", "minLength": 1},
        "tags": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true}
      }
    },
    "dataset_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  },
  "additionalProperties": false
}
