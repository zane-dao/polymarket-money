{
  "name": "polymarket-money",
  "version": "0.1.0",
  "private": true,
  "description": "Safety-first Polymarket domain and execution contracts",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test dist/tests/unit/*.test.js",
    "paper:mvp": "npm run build && node --use-env-proxy dist/scripts/kj-paper-mvp.js",
    "paper:signal-compare-mvp": "npm run build && node --use-env-proxy dist/scripts/kj-signal-compare-mvp.js",
    "paper:signal-compare-report": "npm run build && node dist/scripts/report-kj-signal-compare.js",
    "paper:signal-compare-campaign-plan": "npm run build && node dist/scripts/create-kj-signal-compare-campaign.js",
    "paper:signal-compare-campaign-run": "npm run build && node --use-env-proxy dist/scripts/run-kj-signal-compare-campaign.js",
    "paper:campaign-plan": "npm run build && node dist/scripts/create-kj-paper-campaign.js",
    "paper:finalize": "npm run build && node dist/scripts/finalize-kj-paper-run.js",
    "paper:report": "npm run build && node dist/scripts/report-kj-paper-run.js",
    "paper:cohort-report": "npm run build && node dist/scripts/report-kj-paper-cohort.js",
    "paper:campaign-cohort-report": "npm run build && node dist/scripts/report-kj-paper-campaign-cohort.js",
    "paper:cohort-observability-report": "npm run build && node dist/scripts/report-kj-paper-cohort-observability.js",
    "paper:campaign-cohort-observability-report": "npm run build && node dist/scripts/report-kj-paper-cohort-observability.js --require-campaign",
    "paper:settle": "npm run build && node --use-env-proxy dist/scripts/settle-kj-paper-journal.js",
    "paper:inspect": "npm run build && node dist/scripts/inspect-kj-paper-journal.js",
    "smoke:readonly": "npm run build && node --use-env-proxy dist/scripts/smoke-capture.js",
    "runtime:live": "npm run build && node --use-env-proxy dist/scripts/live-runtime.js"
  },
  "devDependencies": {
    "@types/node": "^24.13.3",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "decimal.js": "10.6.0"
  }
}
