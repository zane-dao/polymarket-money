{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://polymarket-money.local/contracts/app-status-v1.schema.json",
  "title": "Desktop application status v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "generatedAtUtc",
    "appVersion",
    "mode",
    "liveTradingEnabled",
    "dataRootConfigured",
    "modules"
  ],
  "properties": {
    "schemaVersion": { "const": "app-status-v1" },
    "generatedAtUtc": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-(0[1-9]|1[0-2])-([0-2][0-9]|3[01])T([01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]Z$"
    },
    "appVersion": { "type": "string", "minLength": 1 },
    "mode": { "const": "paper-only" },
    "liveTradingEnabled": { "const": false },
    "dataRootConfigured": { "type": "boolean" },
    "modules": {
      "type": "array",
      "items": { "$ref": "#/$defs/moduleStatus" }
    }
  },
  "$defs": {
    "moduleStatus": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["moduleId", "availability"],
          "properties": {
            "moduleId": { "type": "string", "minLength": 1 },
            "availability": { "const": "available" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["moduleId", "availability", "reason"],
          "properties": {
            "moduleId": { "type": "string", "minLength": 1 },
            "availability": { "const": "unavailable" },
            "reason": { "type": "string", "minLength": 1 }
          }
        }
      ]
    }
  }
}
