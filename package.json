{
  "name": "polymarket-money",
  "version": "0.1.0",
  "private": true,
  "description": "Safety-first Polymarket domain and execution contracts",
  "type": "module",
  "scripts": {
    "build": "node --input-type=module --eval \"import { rmSync } from 'node:fs'; rmSync('dist', { recursive: true, force: true });\" && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test dist/tests/unit/*.test.js dist/backend/core/tests/unit/*.test.js dist/frontend/tests/*.test.js dist/backend/tests/*.test.js dist/strategies/tests/*.test.js",
    "paper:mvp": "npm run build && node --use-env-proxy dist/scripts/kj-paper-mvp.js",
    "paper:signal-compare-mvp": "npm run build && node --use-env-proxy dist/scripts/kj-signal-compare-mvp.js",
    "paper:signal-compare-report": "npm run build && node dist/scripts/report-kj-signal-compare.js",
    "paper:signal-compare-campaign-plan": "npm run build && node dist/scripts/create-kj-signal-compare-campaign.js",
    "paper:signal-compare-campaign-run": "npm run build && node --use-env-proxy dist/scripts/run-kj-signal-compare-campaign.js",
    "paper:campaign-plan": "npm run build && node dist/scripts/create-kj-paper-campaign.js",
    "paper:finalize": "npm run build && node dist/scripts/finalize-kj-paper-run.js",
    "paper:report": "npm run build && node dist/scripts/report-kj-paper-run.js",
    "paper:cohort-report": "npm run build && node dist/scripts/report-kj-paper-cohort.js",
    "paper:campaign-cohort-report": "npm run build && node dist/scripts/report-kj-paper-campaign-cohort.js",
    "paper:cohort-observability-report": "npm run build && node dist/scripts/report-kj-paper-cohort-observability.js",
    "paper:campaign-cohort-observability-report": "npm run build && node dist/scripts/report-kj-paper-cohort-observability.js --require-campaign",
    "paper:settle": "npm run build && node --use-env-proxy dist/scripts/settle-kj-paper-journal.js",
    "paper:inspect": "npm run build && node dist/scripts/inspect-kj-paper-journal.js",
    "mvp:console": "npm run build && node dist/scripts/mvp-console.js",
    "smoke:readonly": "npm run build && node --use-env-proxy dist/scripts/smoke-capture.js",
    "runtime:live": "npm run build && node --use-env-proxy dist/scripts/live-runtime.js",
    "frontend:dev": "vite --config frontend/vite.config.ts",
    "frontend:build": "vite build --config frontend/vite.config.ts",
    "frontend:test": "vitest run --config frontend/vite.config.ts",
    "frontend:e2e": "playwright test --config frontend/playwright.config.ts",
    "web:serve": "npm run build && npm run frontend:build && node --use-env-proxy dist/scripts/workbench-web-server.js",
    "release:candidate": "node scripts/local-environments.mjs refresh-candidate",
    "release:promote": "node scripts/local-environments.mjs promote",
    "sim:production": "node scripts/local-environments.mjs serve production",
    "sim:staging": "node scripts/local-environments.mjs serve staging",
    "ports:start": "node scripts/local-ports.mjs start",
    "ports:stop": "node scripts/local-ports.mjs stop",
    "ports:restart": "node scripts/local-ports.mjs restart",
    "ports:status": "node scripts/local-ports.mjs status",
    "dev": "node scripts/local-environments.mjs dev"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^7.0.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.13.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "jsdom": "^29.1.1",
    "typescript": "^5.9.3",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "decimal.js": "10.6.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
